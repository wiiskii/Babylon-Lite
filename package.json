{
    "name": "babylon-lite-workspace",
    "private": true,
    "packageManager": "pnpm@9.15.4",
    "scripts": {
        "dev": "pnpm --filter @babylon-lite/parity-harness dev",
        "dev:lab": "tsx scripts/build-bundle-scenes.ts && pnpm --filter @babylon-lite/lab dev",
        "build": "pnpm --filter babylon-lite build",
        "build:prod": "pnpm --filter babylon-lite build:prod",
        "build:bundle-scenes": "tsx scripts/build-bundle-scenes.ts",
        "test": "pnpm build:bundle-scenes && pnpm test:parity",
        "test:watch": "vitest",
        "test:bundle-size": "npx playwright test tests/parity/bundle-size.spec.ts",
        "test:perf": "npx playwright test --config playwright.perf.config.ts",
        "test:parity": "npx playwright test tests/parity",
        "test:all": "npx playwright test && npx playwright test --config playwright.perf.config.ts",
        "test:bundle-delta": "npx playwright test tests/parity/bundle-size-delta.spec.ts",
        "test:perf-regression": "npx playwright test --config playwright.perf.config.ts tests/perf/perf-regression.spec.ts",
        "test:parity-cloud": "tsx scripts/run-browserstack.ts playwright test --config config/playwright.parity-cloud.config.ts",
        "test:perf-cloud": "tsx scripts/run-browserstack.ts playwright test --config config/playwright.perf-cloud.config.ts tests/perf/perf-regression.spec.ts",
        "snapshot:bundle-baseline": "tsx scripts/snapshot-bundle-baseline.ts",
        "build:perf-baseline": "tsx scripts/build-perf-baseline.ts",
        "lint": "eslint . && tsc -p packages/babylon-lite/tsconfig.json --noEmit",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"packages/**/src/**/*.ts\" \"apps/**/src/**/*.ts\" \"tests/**/*.ts\"",
        "format:check": "prettier --check \"packages/**/src/**/*.ts\" \"apps/**/src/**/*.ts\" \"tests/**/*.ts\"",
        "analyze-bundle": "tsx scripts/analyze-bundle.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@types/pngjs": "^6.0.5",
        "@webgpu/types": "^0.1.52",
        "browserstack-node-sdk": "^1.52.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "miniray": "^0.3.1",
        "pngjs": "^7.0.0",
        "rollup-plugin-visualizer": "^7.0.1",
        "terser": "^5.46.1",
        "tsx": "^4.21.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.57.2",
        "vite": "^6.0.0",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "prettier": "^3.8.1"
    }
}
