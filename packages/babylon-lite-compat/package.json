{
    "name": "@babylonjs/lite-compat",
    "version": "0.0.1",
    "license": "Apache-2.0",
    "type": "module",
    "description": "Opt-in Babylon.js-shaped compatibility layer implemented on top of the Babylon Lite public API. Provides a migration runway from Babylon.js to Babylon Lite.",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        },
        "./vite": {
            "import": "./src/vite.ts",
            "types": "./src/vite.ts"
        },
        "./rollup": {
            "import": "./src/rollup.ts",
            "types": "./src/rollup.ts"
        },
        "./webpack": {
            "import": "./src/webpack.ts",
            "types": "./src/webpack.ts"
        },
        "./esbuild": {
            "import": "./src/esbuild.ts",
            "types": "./src/esbuild.ts"
        },
        "./navigation": {
            "import": "./src/navigation/navigation.ts",
            "types": "./src/navigation/navigation.ts"
        },
        "./recast-shim": {
            "import": "./src/navigation/recast-shim.ts",
            "types": "./src/navigation/recast-shim.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch"
    },
    "sideEffects": false,
    "dependencies": {
        "babylon-lite": "workspace:*",
        "@recast-navigation/core": "0.43.0",
        "@recast-navigation/generators": "0.43.0",
        "@recast-navigation/wasm": "0.43.0"
    },
    "devDependencies": {
        "@webgpu/types": "^0.1.52",
        "typescript": "^5.7.0",
        "vite": "^6.0.0",
        "vite-plugin-dts": "^4.5.4"
    }
}
